# Parley loop harness — active sprint scope for the pre-commit sentinel
# and TDD phase for the verification gate.
# 'sprint:' selects which scope regex is enforced. 'phase:' is red (tests
# must fail) or green (tests must pass). Only the HUMAN operator edits
# this file — agents never advance the sprint or flip the phase.
sprint: 1
phase: red
scope-0: ^(src/compat/|src/domain/|tests/|scripts/|docs/|\.githooks/|\.github/|\.gitignore$|\.parley_sprint_scope$|SPRINT0-NOTES\.md$|AGENTS\.md$|README\.md$|LICENSE$|CONTRIBUTING\.md$)
scope-1: ^(src/compat/|src/domain/|src/manifest/|tests/|scripts/|docs/|\.githooks/|\.github/|\.gitignore$|\.parley_sprint_scope$|SPRINT1-NOTES\.md$|AGENTS\.md$|README\.md$|LICENSE$|CONTRIBUTING\.md$)
